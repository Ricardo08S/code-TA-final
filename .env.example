AUTHOR_PROFILE_CACHE_PATH=/path/to/author_profile_cache.pkl
QUERY_TITLE=privacy preserving author recommendation
QUERY_KEYWORDS=homomorphic encryption
QUERY_ABSTRACT=

# Baseline (plaintext, full 384-dim, semua author)
BASELINE_TOP_K=5

# S1 - TFHE E2E surrogate (same encrypted top-1 flow as code-TFHE UC02)
S1_MAX_AUTHORS=16
S1_MAX_SUBPROFILES=2
S1_TOP_K=1
S1_N_FEATURES=16
S1_TARGET_DIM=16
S1_COEF_SCALE=4
S1_PROFILE_SCALE=2
S1_ALPHA=1.0
S1_SERVER_DEVICE=cuda

# S2a - TFHE dengan encrypted top-K ranking (max 32 authors, batas algoritmik)
S2A_MAX_AUTHORS=16
S2A_TOP_K=5
S2A_REDUCE_DIM=64
S2A_REDUCE_METHOD=pca
S2A_SERVER_DEVICE=gpu
S2A_ENC_TOPK_SCALE=1
S2A_CANDIDATE_MODE=first

# S2b - OpenFHE CKKS + bootstrapping untuk approximate pairwise ranking
# Pool kecil karena EvalBootstrap per author mahal; full 2620 author tidak praktis.
S2B_MAX_AUTHORS=20
S2B_TOP_K=5
S2B_REDUCE_DIM=64
S2B_REDUCE_METHOD=pca
S2B_CANDIDATE_MODE=first

# S3 - TFHE E2E surrogate, ranking di client (Phase 1 only)
# max_authors opsional untuk testing subset author; alpha dicari otomatis via RidgeCV
S3_MAX_AUTHORS=
S3_TOP_K=5
S3_N_FEATURES=64
S3_TARGET_DIM=32
S3_COEF_SCALE=8
S3_PROFILE_SCALE=1
S3_SERVER_DEVICE=gpu

# S4a - TFHE dot product (MiniLM full 384-dim, semua author)
S4A_TOP_K=5
S4A_SERVER_DEVICE=gpu

# S4b - CKKS dot product (MiniLM full 384-dim, semua author)
S4B_TOP_K=5

# S4c - PHE Paillier dot product (MiniLM full 384-dim, semua author)
S4C_TOP_K=5
S4C_KEY_BITS=2048

# S4d - SHE BGV via OpenFHE (MiniLM full 384-dim, semua author)
# plain_modulus dihitung otomatis: prima pertama > 2×scale² agar tidak overflow dot product
S4D_TOP_K=5
S4D_MULT_DEPTH=2

# S4e - SHE BFV via TenSEAL (MiniLM full 384-dim, semua author)
# poly_modulus_degree dihitung otomatis: min power-of-2 ≥ 2×EMBED_DIM, min 4096 untuk keamanan
# plain_modulus dihitung otomatis: prima pertama > 2×scale²
S4E_TOP_K=5
